<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fillViewport="true"
    android:background="@color/bg_light">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- Header -->
        <TextView
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:text="Patient Notes"
            android:textSize="26sp"
            android:textStyle="bold"
            android:textColor="@color/primary"/>

        <!-- Search bar -->
        <EditText
            android:layout_width="match_parent"
            android:layout_height="50dp"
            android:layout_marginTop="15dp"
            android:hint="Search ward/shift"
            android:background="@drawable/white_card"
            android:padding="12dp"
            android:inputType="text"/>

        <!-- Filter buttons -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginTop="15dp"
            android:orientation="horizontal"
            android:gravity="start"
            android:weightSum="3">

            <Button
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="ALL"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"/>

            <Button
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="Recent"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"/>

            <Button
                android:layout_width="0dp"
                android:layout_weight="1"
                android:layout_height="40dp"
                android:text="Critical"
                android:layout_marginStart="8dp"
                android:backgroundTint="@color/primary"
                android:textColor="@color/white"/>
        </LinearLayout>

        <!-- Notes container -->
        <LinearLayout
            android:id="@+id/notesContainer"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:layout_marginTop="15dp">

            <!-- Patient Note 1 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/white_card"
                android:elevation="4dp"
                android:padding="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Patient 101 - Vitals Update"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Updated 09:30 AM, Ward A"
                        android:textColor="#666"/>
                </LinearLayout>

                <Button
                    android:layout_width="90dp"
                    android:layout_height="40dp"
                    android:text="OPEN"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/primary"/>
            </LinearLayout>

            <!-- Patient Note 2 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/white_card"
                android:elevation="4dp"
                android:padding="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Patient 205 - Medication"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Updated 11:00 AM, ICU"
                        android:textColor="#666"/>
                </LinearLayout>

                <Button
                    android:layout_width="90dp"
                    android:layout_height="40dp"
                    android:text="OPEN"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/primary"/>
            </LinearLayout>

            <!-- Patient Note 3 -->
            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                android:background="@drawable/white_card"
                android:elevation="4dp"
                android:padding="16dp"
                android:orientation="horizontal">

                <LinearLayout
                    android:layout_width="0dp"
                    android:layout_weight="1"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Patient 312 - Observation Note"
                        android:textStyle="bold"/>

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Updated 01:15 PM, Emergency"
                        android:textColor="#666"/>
                </LinearLayout>

                <Button
                    android:layout_width="90dp"
                    android:layout_height="40dp"
                    android:text="OPEN"
                    android:textColor="#FFFFFF"
                    android:backgroundTint="@color/primary"/>
            </LinearLayout>

        </LinearLayout>

    </LinearLayout>
</ScrollView>
