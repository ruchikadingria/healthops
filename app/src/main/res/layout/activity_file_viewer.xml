<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="@color/bg_light"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="20dp">

        <!-- 🔙 HEADER -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="16dp">

            <!-- Back Button -->
            <ImageView
                android:id="@+id/btnBack"
                android:layout_width="28dp"
                android:layout_height="28dp"
                android:src="@android:drawable/ic_media_previous"
                android:tint="@color/primary"
                android:padding="4dp"
                android:contentDescription="Back"/>

            <!-- Icon -->
            <ImageView
                android:layout_width="30dp"
                android:layout_height="30dp"
                android:layout_marginStart="12dp"
                android:src="@drawable/ic_file"
                app:tint="@color/primary"/>

            <!-- Title -->
            <TextView
                android:layout_width="wrap_content"
                android:layout_height="wrap_content"
                android:text="File Viewer"
                android:textColor="@color/text_primary"
                android:textStyle="bold"
                android:textSize="22sp"
                android:layout_marginStart="10dp"/>
        </LinearLayout>

        <!-- 📄 CARD -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            app:cardCornerRadius="20dp"
            app:cardElevation="8dp"
            app:cardBackgroundColor="@color/card_bg">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="20dp">

                <!-- Title -->
                <TextView
                    android:id="@+id/tvTitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Ward A"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:textColor="@color/text_primary"/>

                <!-- Subtitle -->
                <TextView
                    android:id="@+id/tvSubtitle"
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Morning Shift"
                    android:textSize="13sp"
                    android:textColor="@color/primary"
                    android:paddingTop="4dp"
                    android:paddingBottom="12dp"/>

                <!-- Description -->
                <TextView
                    android:id="@+id/tvDescription"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Detailed information about this ward and its responsibilities."
                    android:textColor="@color/text_secondary"
                    android:textSize="14sp"
                    android:lineSpacingExtra="4dp"
                    android:paddingBottom="16dp"/>

                <!-- Divider -->
                <View
                    android:layout_width="match_parent"
                    android:layout_height="1dp"
                    android:background="#E0E0E0"
                    android:layout_marginBottom="16dp"/>

                <!-- Info Section -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical">

                    <!-- Time -->
                    <TextView
                        android:id="@+id/tvTimeLabel"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Shift Time"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvTime"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="08:00 AM - 02:00 PM"
                        android:textColor="@color/text_secondary"
                        android:paddingBottom="10dp"/>

                    <!-- Row 2 -->
                    <TextView
                        android:id="@+id/tvRow2Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Assigned Nurses"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvRow2Value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="12 Nurses"
                        android:textColor="@color/text_secondary"
                        android:paddingBottom="10dp"/>

                    <!-- Row 3 -->
                    <TextView
                        android:id="@+id/tvRow3Label"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Tasks"
                        android:textStyle="bold"
                        android:textColor="@color/text_primary"/>

                    <TextView
                        android:id="@+id/tvRow3Value"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="Routine rounds and vitals monitoring"
                        android:textColor="@color/text_secondary"/>

                    <!-- MARK AS DONE BUTTON -->
                    <Button
                        android:id="@+id/btnMarkDone"
                        android:layout_width="match_parent"
                        android:layout_height="48dp"
                        android:layout_marginTop="20dp"
                        android:text="Mark as Done"
                        android:textColor="@color/white"
                        android:textStyle="bold"
                        android:backgroundTint="@color/primary"/>

                </LinearLayout>

            </LinearLayout>

        </androidx.cardview.widget.CardView>

    </LinearLayout>

</ScrollView>